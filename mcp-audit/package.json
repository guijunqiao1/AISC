{
  "name": "gjq-audit",
  "version": "1.0.12",
  "description": "Audit npm dependency vulnerabilities for local or remote projects.",
  "main": "index.js",
  "type": "module",
  "exports": {
    ".": "./index.js"
  },
  "files": [
    "index.js",
    "bin/cli.js",
    "README.md",
    "src/**/*.js",
    "src/render/template/*.ejs",
    "!src/**/test/**",
    "!src/main/**",
    "package.json"
  ],
  "bin": {
    "gjq-audit": "bin/cli.js",
    "mcp-audit": "bin/cli.js"
  },
  "scripts": {
    "test": "echo \"No tests configured\"",
    "cli": "node ./bin/cli.js",
    "mcp": "node ./bin/cli.js --mcp",
    "prepublishOnly": "npm pack --dry-run"
  },
  "keywords": [
    "audit",
    "security",
    "mcp",
    "cli",
    "npx"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.1",
    "ejs": "^3.1.10",
    "zod": "^3.25.76"
  }
}
